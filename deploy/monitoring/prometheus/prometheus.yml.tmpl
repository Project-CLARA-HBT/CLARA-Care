global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: clara_api_metrics
    metrics_path: /metrics
    scheme: http
    static_configs:
      - targets: ["api:8000"]

  - job_name: clara_ml_metrics
    metrics_path: /metrics
    scheme: http
    static_configs:
      - targets: ["ml:8010"]
